# Locale Docker (MySQL). Su Render usa il DATABASE_URL Postgres (managed, persistente).
DATABASE_URL=mysql+pymysql://club_user:club_pass@mysql:3306/club_business_ia
# Solo Postgres: default require (SSL, adatto a Render). Postgres locale senza SSL: disable
# DATABASE_SSLMODE=disable
# Origini CORS del frontend (virgole, senza spazi). Esempio Render:
# ALLOWED_ORIGINS=https://tuo-frontend.onrender.com,http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
JWT_SECRET=change_me_super_secret
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
WEBHOOK_AUTH_TOKEN=change_me_webhook_token
ADMIN_EMAIL=admin@clubbusinessia.local
ADMIN_PASSWORD=Admin123!
ADMIN_NAME=Founder Admin
ALLOWED_TARGETS=avvocati,pasticceri,ristoratori,gelatai,parrucchieri,medici,commercialisti,ingegneri,architetti,geometri,notai,ragionieri,consulenti_fiscali,consulenti_lavoro,agenti_immobiliari,farmacie,dentisti,veterinari,psicologi,fotografi,videomaker,estetisti,personal_trainer,alberghi,agriturismi,imprese_edili,elettricisti,idraulici,meccanici,influencer,wedding_planner,aziende,privati
REQUIRE_APPROVAL=false
THREE_FACTOR_REQUIRED=false
EMAIL_OTP_DEV_EXPOSE=true
# Reset password senza SMTP (solo dev): stesso default di EMAIL_OTP_DEV_EXPOSE se omesso
# PASSWORD_RESET_DEV_EXPOSE=false
# --- Email (obbligatorio in prod per codice verifica e reset password) ---
# Senza SMTP_HOST+USER+PASSWORD non parte nessuna email; GET /health mostra smtp_configured.
# Brevo: SMTP_HOST=smtp-relay.brevo.com SMTP_PORT=587 SMTP_USER=xxx@smtp-brevo.com SMTP_PASSWORD=<chiave SMTP>
# SMTP_FROM deve essere un mittente verificato in Brevo (anche una Gmail se l'hai aggiunta come sender).
# Gmail diretto: smtp.gmail.com:587 + password per le app (non la password account normale).
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=noreply@tuodominio.it
# SMTP_USE_TLS=true
# SMTP_USE_SSL=false
# SMTP_DEBUG=false
# Solo se true: OTP prima della creazione account (flusso legacy). La vecchia REQUIRE_REGISTRATION_OTP non viene piu letta.
ENABLE_LEGACY_PRE_SIGNUP_OTP=false
# Dopo la registrazione: invia codice via email per verificare l'account (SMTP richiesto in prod).
SEND_POST_REGISTRATION_OTP=true
# Blocca il login finche l'email non e verificata (con codice post-registrazione).
REQUIRE_EMAIL_VERIFICATION=true
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
SITE_CAPACITY=200
